# CBC Learning Ecosystem — Backend Environment Configuration
# Copy this file to .env and fill in the values appropriate for your environment

# ━━━ NODE ENVIRONMENT ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NODE_ENV=development

# ━━━ SERVER ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PORT=5000
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ━━━ DATABASE (PostgreSQL) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Option 1: Use DATABASE_URL (Railway, Render, Neon — override individual vars)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Option 2: Use discrete variables (local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cbc_learning_dev
DB_USER=postgres
DB_PASSWORD=dev_password_123
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ━━━ REDIS ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Option 1: Use REDIS_URL (Railway auto-injects when Redis is linked)
# REDIS_URL=redis://user:password@host:6379

# Option 2: Use discrete variables
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ━━━ JWT SECRETS (MUST be >64 chars random) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev_jwt_secret_minimum_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=dev_refresh_secret_minimum_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ENCRYPTION_KEY=dev_encryption_key_32chars_xxxxxxx

# ━━━ M-PESA INTEGRATION (Safaricom Daraja API) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=sandbox_key
MPESA_CONSUMER_SECRET=sandbox_secret
MPESA_PASSKEY=sandbox_passkey
MPESA_SHORTCODE=174379

# ━━━ SMS PROVIDER (Africa's Talking) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AT_API_KEY=
AT_USERNAME=

# ━━━ LOGGING ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LOG_LEVEL=info
