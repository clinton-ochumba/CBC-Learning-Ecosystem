{
  "name": "cbc-learning-ecosystem-backend",
  "version": "1.0.0",
  "description": "CBC Learning Ecosystem – Backend API (Kenya CBC, M-Pesa, offline-first)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate": "npm run build && knex --knexfile knexfile.js --env ${NODE_ENV:-development} migrate:latest",
    "migrate:dev": "ts-node -O '{\"module\":\"commonjs\"}' node_modules/.bin/knex --knexfile knexfile.js --env ${NODE_ENV:-development} migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.js --env ${NODE_ENV:-development} migrate:rollback",
    "seed": "knex --knexfile knexfile.js --env ${NODE_ENV:-development} seed:run",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "africastalking": "^0.7.9",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "ip-range-check": "^0.2.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
